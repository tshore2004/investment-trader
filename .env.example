# ── Database ────────────────────────────────────────────────────────────────
DB_USER=hedge
DB_PASSWORD=changeme
DB_NAME=hedge_quant
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://hedge:changeme@localhost:5432/hedge_quant

# ── Interactive Brokers (TWS / IB Gateway) ──────────────────────────────────
IB_HOST=127.0.0.1
IB_PORT=7497          # 7497 = TWS paper, 7496 = TWS live, 4002 = Gateway paper
IB_CLIENT_ID=1
IB_ACCOUNT=           # e.g. DU1234567 for paper, U1234567 for live

# ── Risk limits ─────────────────────────────────────────────────────────────
MAX_POSITION_USD=50000
MAX_PORTFOLIO_DRAWDOWN_PCT=0.05
MAX_ORDER_SIZE=100

# ── Trading / strategy ───────────────────────────────────────────────────────
TRADING_ENABLED=false        # true = strategies submit real orders, false = dry-run logging only
MAX_TRADES_PER_DAY=5         # per-strategy-instance cap on new orders per UTC day
WATCHLIST_SYMBOLS=AAPL       # comma-separated symbols, e.g. AAPL,MSFT,SPY

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json       # json | console
